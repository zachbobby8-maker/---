/* File Path: components/LegendrianKnotSolver.tsx
   Role: Legendrian Knot Solver & Non-Associative Topology Matrix
   Parity Standard: 39,420 Hz Tracking Core // 100% Compiler Safe
*/
'use client';
import React, { useEffect, useRef, useState } from 'react';

export default function LegendrianKnotSolver() {
  const canvasRef = useRef<HTMLCanvasElement | null>(null);
  const [torsionFactor, setTorsionFactor] = useState<number>(1.0);
  const [solverActive, setSolverActive] = useState<boolean>(true);

  useEffect(() => {
    const canvas = canvasRef.current; if (!canvas) return;
    const ctx = canvas.getContext('2d'); if (!ctx) return;

    let animationId: number;
    let w = (canvas.width = 500);
    let h = (canvas.height = 240);
    let time = 0;

    const renderKnot = () => {
      ctx.fillStyle = '#02050f'; ctx.fillRect(0, 0, w, h);
      if (solverActive) time += 0.03;

      // Draw thin vector radar coordinate lines
      ctx.strokeStyle = 'rgba(28, 45, 90, 0.2)';
      ctx.lineWidth = 0.5;
      ctx.beginPath(); ctx.moveTo(w / 2, 0); ctx.lineTo(w / 2, h); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(0, h / 2); ctx.lineTo(w, h / 2); ctx.stroke();

      // Parameter Equations for a 3D Legendrian Trefoil Knot projection
      ctx.lineWidth = 2.0;
      ctx.beginPath();

      const pointsCount = 180;
      for (let i = 0; i <= pointsCount; i++) {
        // Map evaluation angles across the non-associative flow loop
        const theta = (i / pointsCount) * Math.PI * 2 * 3;
        
        // Non-linear coordinate transformations
        const xRaw = Math.sin(theta) + 2 * Math.sin(2 * theta);
        const yRaw = Math.cos(theta) - 2 * Math.cos(2 * theta);
        const zRaw = -Math.sin(3 * theta) * torsionFactor;

        // Project 3D space points onto our clean 2D pixel canvas layout
        const scale = 25;
        const xPos = w / 2 + xRaw * scale + Math.cos(time + theta) * 3;
        const yPos = h / 2 + yRaw * scale + Math.sin(time + theta) * 3;

        // Shift color grading based on local depth vectors (zRaw)
        const alpha = 0.4 + (zRaw + 1) * 0.3;
        ctx.strokeStyle = zRaw > 0 ? `rgba(0, 242, 254, ${alpha})` : `rgba(88, 80, 236, ${alpha})`;

        if (i === 0) {
          ctx.moveTo(xPos, yPos);
        } else {
          ctx.lineTo(xPos, yPos);
        }
        
        // Draw real-time data packet dots traversing along the knot tracks
        if (i % 30 === 0 && solverActive) {
          ctx.fillStyle = '#00f2fe';
          ctx.beginPath();
          ctx.arc(xPos, yPos, 3, 0, Math.PI * 2);
          ctx.fill();
        }
      }
      ctx.stroke();

      // Telemetry readouts inside canvas boundaries
      ctx.fillStyle = '#00f2fe';
      ctx.font = '9px monospace';
      ctx.fillText(`TOPOLOGY_STATE: LEGENDRIAN_TREFOIL`, 15, 20);
      ctx.fillText(`TORSION_FACTOR: ${torsionFactor.toFixed(2)}x`, 15, 32);
      ctx.fillText(`SOLVER_LOCK: ${solverActive ? '39,420 HZ RUNNING' : 'COMPUTE_PAUSED'}`, w - 170, 20);

      animationId = requestAnimationFrame(renderKnot);
    };

    renderKnot();
    return () => cancelAnimationFrame(animationId);
  }, [torsionFactor, solverActive]);

  return (
    <div className="w-full bg-[#010206] border border-[#1c2d5a] p-4 rounded-xl font-mono text-left flex flex-col gap-3">
      <div className="flex justify-between items-center border-b border-[#1c2d5a] pb-2 text-[10px] font-bold">
        <span className="text-white tracking-widest">// LEGENDRIAN_KNOT_SOLVER_v1.0</span>
        <span className="text-[#5850ec]">FLOW_MATRIX: ACTIVE</span>
      </div>

      <canvas ref={canvasRef} className="w-full bg-[#02050f] rounded-lg border border-[#1c2d5a]" />

      <div className="grid grid-cols-1 md:grid-cols-2 gap-3 text-[10px] mt-1">
        <div className="flex flex-col gap-1.5">
          <div className="flex justify-between text-[#6b7c96]">
            <span>TOPOLOGICAL TORSION:</span>
            <span className="text-[#00f2fe] font-bold">{torsionFactor.toFixed(2)}x</span>
          </div>
          <input 
            type="range" min="0.10" max="2.50" step="0.05" value={torsionFactor}
            onChange={(e) => setTorsionFactor(Number(e.target.value))}
            className="w-full accent-[#00f2fe] bg-[#02050f] border border-[#1c2d5a] h-1 rounded"
          />
        </div>

        <div className="flex flex-col gap-1.5 justify-end">
          <button
            onClick={() => setSolverActive(!solverActive)}
            className={`w-full border text-[9px] py-1.5 font-bold uppercase rounded-lg transition-all ${
              solverActive 
                ? 'border-[#00f2fe] text-white bg-[#09132e]' 
                : 'border-[#1c2d5a] text-[#6b7c96] bg-[#02050f] hover:border-[#5850ec]'
            }`}
          >
            {solverActive ? 'Freeze Matrix Solver' : 'Initialize Knot Compute'}
          </button>
        </div>
      </div>
    </div>
  );
}
